---
// Root: send the visitor to the closest match for their browser language.
// A tiny inline script does the redirect; without JS, a short menu is shown
// (no auto meta-refresh, which would race the script and force everyone to /en/).
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pepe, the AI agent runtime you run yourself</title>
    <link rel="icon" type="image/svg+xml" href="/pepe-icon.svg" />
    <script is:inline>
      (function () {
        var supported = ["en", "es", "pt-br", "pt-pt"];
        var langs = (navigator.languages && navigator.languages.length
          ? navigator.languages
          : [navigator.language || "en"]).map(function (l) {
          return String(l).toLowerCase();
        });

        function closest(prefs) {
          // 1) exact region match (pt-br, pt-pt, es, en)
          for (var i = 0; i < prefs.length; i++) {
            if (supported.indexOf(prefs[i]) !== -1) return prefs[i];
          }
          // 2) base-language match; Portuguese with no region defaults to pt-br
          for (var i = 0; i < prefs.length; i++) {
            var base = prefs[i].split("-")[0];
            if (base === "pt") return "pt-br";
            for (var j = 0; j < supported.length; j++) {
              if (supported[j].split("-")[0] === base) return supported[j];
            }
          }
          return "en";
        }

        location.replace("/" + closest(langs) + "/");
      })();
    </script>
    <style>
      body { background: #0a0a0b; color: #a1a1aa; font-family: system-ui, sans-serif; text-align: center; padding: 60px 24px; }
      a { display: inline-block; margin: 6px; padding: 10px 18px; border: 1px solid #26262b; border-radius: 10px; color: #fb923c; text-decoration: none; }
      a:hover { border-color: #3f3f46; }
    </style>
  </head>
  <body>
    <p>Choose your language</p>
    <a href="/en/">English</a>
    <a href="/es/">Español</a>
    <a href="/pt-br/">Português (BR)</a>
    <a href="/pt-pt/">Português (PT)</a>
  </body>
</html>
