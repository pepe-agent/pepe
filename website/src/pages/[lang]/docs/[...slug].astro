---
import Base from "../../../layouts/Base.astro";
import { locales, type Locale } from "../../../i18n/ui";
import { withLocale } from "../../../i18n/utils";
import { docsNav, allSlugs, groupLabels } from "../../../docs/nav";

// Eager-load every doc markdown; key by "<lang>/<slug>".
const mods = import.meta.glob("../../../docs/**/*.md", { eager: true }) as Record<string, any>;

function docFor(lang: string, slug: string) {
  const key = Object.keys(mods).find((k) => k.endsWith(`/${lang}/${slug}.md`));
  if (key) return mods[key];
  const en = Object.keys(mods).find((k) => k.endsWith(`/en/${slug}.md`));
  return en ? mods[en] : null;
}

export function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of locales) {
    for (const slug of allSlugs) {
      paths.push({ params: { lang, slug: slug === "index" ? undefined : slug } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Locale;
const slug = (Astro.params.slug as string | undefined) ?? "index";
const mod = docFor(lang, slug);
const { Content, frontmatter } = mod;

const hrefOf = (s: string) => withLocale(lang, s === "index" ? "/docs/" : `/docs/${s}/`);
const titleOf = (s: string) => docFor(lang, s)?.frontmatter?.title ?? s;

const sidebar = docsNav.map((g) => ({
  label: groupLabels[lang][g.group],
  items: g.slugs.map((s) => ({ slug: s, title: titleOf(s), href: hrefOf(s) })),
}));

const searchCopy: Record<Locale, { label: string; placeholder: string; empty: string; loading: string; error: string }> = {
  en: {
    label: "Search docs",
    placeholder: "Search docs...",
    empty: "No results",
    loading: "Searching...",
    error: "Search unavailable",
  },
  es: {
    label: "Buscar en la documentación",
    placeholder: "Buscar en la documentación...",
    empty: "Sin resultados",
    loading: "Buscando...",
    error: "Búsqueda no disponible",
  },
  "pt-br": {
    label: "Buscar na documentação",
    placeholder: "Buscar na documentação...",
    empty: "Nenhum resultado",
    loading: "Buscando...",
    error: "Busca indisponível",
  },
  "pt-pt": {
    label: "Pesquisar na documentação",
    placeholder: "Pesquisar na documentação...",
    empty: "Sem resultados",
    loading: "A pesquisar...",
    error: "Pesquisa indisponível",
  },
};

// Only shown on narrow screens, where the 32 links are folded away behind it.
const menuCopy: Record<Locale, string> = {
  en: "All pages",
  es: "Todas las páginas",
  "pt-br": "Todas as páginas",
  "pt-pt": "Todas as páginas",
};

const idx = allSlugs.indexOf(slug);
const prev = idx > 0 ? allSlugs[idx - 1] : null;
const next = idx < allSlugs.length - 1 ? allSlugs[idx + 1] : null;
const search = searchCopy[lang];
const menuLabel = menuCopy[lang];

// Home > Docs > this page - the three levels that always have a real,
// navigable URL. Not attempting a 4th "section" level: a nav group's label
// (e.g. "Configure") doesn't reliably map to one of its own pages, so a
// breadcrumb entry for it would have nowhere honest to link. On the docs
// index itself, "Docs" and "this page" are the same URL, so that case only
// gets two levels - a third identical entry would just be noise.
const site = Astro.site ?? Astro.url.origin;
const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Pepe", item: new URL(withLocale(lang, "/"), site).href },
  { "@type": "ListItem", position: 2, name: "Docs", item: new URL(hrefOf("index"), site).href },
];
if (slug !== "index") {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 3,
    name: frontmatter.title,
    item: new URL(hrefOf(slug), site).href,
  });
}
const breadcrumbJsonLd = { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: breadcrumbItems };
---

<Base title={`${frontmatter.title} · Pepe docs`} description={frontmatter.description} lang={lang} docs={true}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <div class="container docs">
    <aside class="docs-nav">
      <div
        class="doc-search"
        data-doc-search
        data-index-url={`/${lang}/docs/search.json`}
        data-empty-label={search.empty}
        data-loading-label={search.loading}
        data-error-label={search.error}
      >
        <label for="doc-search-input">{search.label}</label>
        <input
          id="doc-search-input"
          type="search"
          placeholder={search.placeholder}
          autocomplete="off"
          spellcheck="false"
          data-doc-search-input
        />
        <div class="doc-search-results" data-doc-search-results hidden></div>
      </div>
      <!--
        Open by default, so the sidebar renders as it always has: on a wide screen CSS
        hides the summary and this is just the list. The script below folds it shut on a
        narrow one, where 32 links between the header and the first paragraph is a scroll
        nobody asked for. Doing it that way round means a reader with no JavaScript gets
        the long list rather than a menu that cannot be opened.
      -->
      <details class="docs-nav-menu" open>
        <summary>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          {menuLabel}
        </summary>
        <div class="docs-nav-scroll">
          {sidebar.map((g) => (
            <div>
              <h4>{g.label}</h4>
              {g.items.map((it) => (
                <a href={it.href} class={it.slug === slug ? "active" : ""}>{it.title}</a>
              ))}
            </div>
          ))}
        </div>
      </details>
      <script is:inline>
        // Before paint, so it never flashes the open list and then collapses.
        if (window.matchMedia("(max-width: 900px)").matches) {
          document.currentScript.previousElementSibling.open = false;
        }
      </script>
    </aside>

    <article class="doc-content">
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="sub">{frontmatter.description}</p>}
      <Content />
      <div class="doc-foot">
        {prev ? <a href={hrefOf(prev)}>← {titleOf(prev)}</a> : <span></span>}
        {next ? <a href={hrefOf(next)}>{titleOf(next)} →</a> : <span></span>}
      </div>
    </article>
  </div>
  <script src="/docs-search.js" defer></script>
</Base>
